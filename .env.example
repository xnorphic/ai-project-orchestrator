# --- AI providers ---------------------------------------------------------
# The orchestrator uses Claude for reasoning (PRD, timeline, tasks, scenarios,
# report) and GPT for fast personnel matching.
#
# Both keys are OPTIONAL. With no keys, every step falls back to a built-in
# deterministic engine so the full demo works offline. Add keys to switch the
# corresponding agents to live AI generation.

ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Optional model overrides --------------------------------------------
# Claude uses Haiku for lighter steps (timeline) and Sonnet for detail-heavy
# reasoning (PRD, tasks, scenarios, report). OpenAI uses a mini model for the
# fast personnel-matching step. Override only if your key lacks access.
# APO_CLAUDE_FAST_MODEL=claude-haiku-4-5
# APO_CLAUDE_DEEP_MODEL=claude-sonnet-4-5
# APO_OPENAI_MODEL=gpt-4o-mini
